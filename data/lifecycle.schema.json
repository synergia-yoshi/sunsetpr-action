{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SunsetPR lifecycle database",
  "type": "object",
  "required": ["version", "checkedAt", "apiDeprecations", "entries"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "checkedAt": { "type": "string", "format": "date" },
    "apiDeprecations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "apiId",
          "apiName",
          "status",
          "shutdownDate",
          "replacement",
          "sourceUrl",
          "sdk",
          "notes"
        ],
        "properties": {
          "provider": { "const": "openai" },
          "apiId": { "enum": ["assistants-api", "videos-api"] },
          "apiName": { "enum": ["Assistants API", "Videos API"] },
          "status": { "const": "deprecated" },
          "shutdownDate": { "type": "string", "format": "date" },
          "replacement": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              { "type": "null" }
            ]
          },
          "sourceUrl": { "type": "string", "format": "uri" },
          "sdk": { "enum": ["OpenAI Assistants", "OpenAI Videos"] },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "modelId",
          "status",
          "shutdownDate",
          "replacement",
          "sourceUrl",
          "replacementConfidence",
          "notes"
        ],
        "properties": {
          "provider": { "enum": ["openai", "anthropic", "gemini"] },
          "modelId": { "type": "string", "minLength": 1 },
          "status": { "enum": ["deprecated", "retired"] },
          "shutdownDate": { "type": "string", "format": "date" },
          "replacement": { "type": "string", "minLength": 1 },
          "sourceUrl": { "type": "string", "format": "uri" },
          "replacementConfidence": { "enum": ["high", "medium", "low"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
