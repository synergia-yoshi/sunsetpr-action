{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SunsetPR lifecycle database",
  "type": "object",
  "required": ["version", "checkedAt", "entries"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "checkedAt": { "type": "string", "format": "date" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "modelId",
          "status",
          "shutdownDate",
          "replacement",
          "sourceUrl",
          "replacementConfidence",
          "notes"
        ],
        "properties": {
          "provider": { "enum": ["openai", "anthropic", "gemini"] },
          "modelId": { "type": "string", "minLength": 1 },
          "status": { "enum": ["deprecated", "retired"] },
          "shutdownDate": { "type": "string", "format": "date" },
          "replacement": { "type": "string", "minLength": 1 },
          "sourceUrl": { "type": "string", "format": "uri" },
          "replacementConfidence": { "enum": ["high", "medium", "low"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
